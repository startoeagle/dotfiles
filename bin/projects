#!/usr/bin/env fish

# TODO: This logic in not quite right
#       we are still creating new session with the previous on
#       that is, we are not detaching correctly

set selected_dir (ls ~/repos | fzf )
set selected_proj (string sub --length 24 $selected_dir)
set session_exist (zellij ls | grep $selected_proj)
set is_in_session (zellij ls | grep '(current)' | awk '{print $1}')

if test '' != "$is_in_session"
    echo "Detach session ($is_in_session)"
    zellij action detach
end

if test -z "$session_exist"
    echo "Creating new session ($selected_proj)"
    pushd "$HOME/repos/$selected_dir"
        zellij attach --create-background $selected_proj
    popd
end

if test -z (echo $session_exist | grep 'attach to resurrect')
    echo "need to delete session ($selected_proj)"
end

zellij attach $selected_proj
